{
  "name": "So-Mot Sales Agent v2.0",
  "nodes": [
    {
      "parameters": {
        "mode": "every",
        "interval": 6,
        "unit": "hours",
        "triggerAtStartup": true
      },
      "name": "🔄 Cron: Sync Menu Every 6 Hours",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [-1600, 1600],
      "id": "menu-sync-trigger"
    },
    {
      "parameters": {
        "url": "https://so-mot.com/wp-json/wc/v3/products",
        "method": "GET",
        "authentication": "basicAuth",
        "basicAuth": {
          "user": "={{ $env.SOMOT_CONSUMER_KEY }}",
          "password": "={{ $env.SOMOT_CONSUMER_SECRET }}"
        },
        "queryParameters": {
          "per_page": "100",
          "orderby": "menu_order",
          "status": "publish"
        }
      },
      "name": "📦 HTTP: Fetch So-Mot Products",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-1200, 1600],
      "id": "fetch-somot-products"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const products = $json.body;\nconst parsed = products.map(p => ({\n  id: p.id,\n  name: p.name,\n  description: p.description,\n  price: parseFloat(p.price),\n  regular_price: parseFloat(p.regular_price),\n  sale_price: p.sale_price ? parseFloat(p.sale_price) : null,\n  category: p.categories[0]?.name || 'Uncategorized',\n  category_id: p.categories[0]?.id,\n  image: p.images[0]?.src,\n  sku: p.sku,\n  stock_quantity: p.stock_quantity,\n  in_stock: p.in_stock,\n  url: p.permalink,\n  type: p.type,\n  timestamp: new Date().toISOString()\n}));\nreturn [{ json: { success: true, total: parsed.length, products: parsed } }];"
      },
      "name": "🔄 Code: Parse Products",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-800, 1600],
      "id": "parse-products"
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "operation": "upsert",
        "baseId": "appXXXXXXXXXXXXXX",
        "tableId": "tblMenuXXXXXXXXXX",
        "keyFields": ["sku"],
        "data": "={{ $json.products }}"
      },
      "name": "💾 Airtable: Cache Menu Data",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2,
      "position": [-400, 1600],
      "id": "airtable-cache-menu"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const products = $json.products.filter(p => p.type === 'variable');\nconst variationRequests = products.map(p => ({ productId: p.id, name: p.name }));\nreturn variationRequests.map(req => ({ json: req }));"
      },
      "name": "📋 Code: Prepare Variations",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [0, 1600],
      "id": "prepare-variations-fetch"
    },
    {
      "parameters": {
        "url": "=https://so-mot.com/wp-json/wc/v3/products/{{ $json.productId }}/variations",
        "method": "GET",
        "authentication": "basicAuth",
        "basicAuth": {
          "user": "={{ $env.SOMOT_CONSUMER_KEY }}",
          "password": "={{ $env.SOMOT_CONSUMER_SECRET }}"
        },
        "queryParameters": {"per_page": "100"}
      },
      "name": "📏 HTTP: Fetch Variations",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [400, 1600],
      "id": "fetch-variations"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "if ($json.statusCode && $json.statusCode >= 400) {\n  return [{ json: { success: false, error: $json.message || 'API Error', statusCode: $json.statusCode, timestamp: new Date().toISOString() } }];\n}\nreturn [$json];"
      },
      "name": "⚠️ Code: Error Handler",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [800, 1600],
      "id": "error-handler"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const products = $json.products;\nconst byCategory = {};\nproducts.forEach(p => {\n  if (!byCategory[p.category]) byCategory[p.category] = [];\n  byCategory[p.category].push({ id: p.id, name: p.name, price: p.price, image: p.image, stock: p.stock_quantity });\n});\nconst aiContext = { menu: byCategory, total_products: products.length, categories: Object.keys(byCategory), last_updated: new Date().toISOString(), ready_for_ai: true };\nreturn [{ json: aiContext }];"
      },
      "name": "🧠 Code: Build AI Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 1600],
      "id": "build-ai-context"
    },
    {
      "parameters": {
        "multipleMethods": true,
        "httpMethod": ["POST", "GET"],
        "path": "meta-sales-agent",
        "responseMode": "responseNode"
      },
      "name": "📱 Facebook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-1296, 432],
      "id": "facebook-trigger"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "26a3553a-f37b-4f46-9a84-3f1661a5d152",
              "name": "trigger",
